{
  "name": "claude-tmux-bridge",
  "version": "2.3.0",
  "description": "MCP server bridging Claude Desktop to an interactive Claude Code tmux session",
  "author": "DaRealDaHoodie",
  "license": "MIT",
  "main": "dist/server.js",
  "bin": {
    "claude-tmux-bridge": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run --config vitest.config.unit.ts",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.unit.ts",
    "test:watch": "vitest --watch --config vitest.config.unit.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.2"
  },
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DaRealDaHoodie/claude-tmux-bridge.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai",
    "llm",
    "tools"
  ],
  "bugs": {
    "url": "https://github.com/DaRealDaHoodie/claude-tmux-bridge/issues"
  },
  "homepage": "https://github.com/DaRealDaHoodie/claude-tmux-bridge#readme"
